# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# Draco WASM artifacts mirrored from node_modules/draco3dgltf by the
# postinstall + prebuild hooks (scripts/copy-draco-wasm.mjs). Treated
# as build output, not source — the contents come straight out of the
# pinned draco3dgltf package.
/public/draco/

# Local-only QA scaffolding for the admin GLB upload flow:
#   scripts/gen-test-glbs.ts          — synthesizes test .glbs of varying sizes
#   scripts/gen-budget-test-glbs.ts   — synthesizes boundary-case .glbs for
#                                       the decoded-budget pre-check tests
#   scripts/mint-test-session.ts      — mints a dev admin session cookie
#   scripts/test-budget.mjs           — direct-call unit test of checkGlbBudget
#   scripts/test-dropzone.mjs         — Playwright dropzone integration test
# None are imported by runtime code; all stay out of git so the
# production surface only ships shipping code.
/scripts/gen-test-glbs.ts
/scripts/gen-budget-test-glbs.ts
/scripts/mint-test-session.ts
/scripts/test-budget.mjs
/scripts/test-dropzone.mjs

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/
