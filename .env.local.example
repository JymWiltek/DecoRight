# ──────────────────────────────────────────────────────────────
# DecoRight — env var contract
# Copy this file to `.env.local` and fill in real values.
# Prefix rules (PROJECT_SPEC v1.2):
#   APP_*              → server-only (never exposed to browser)
#   NEXT_PUBLIC_APP_*  → safe for client bundle
# ──────────────────────────────────────────────────────────────

# Supabase — client-visible
NEXT_PUBLIC_APP_SUPABASE_URL=
NEXT_PUBLIC_APP_SUPABASE_ANON_KEY=

# Supabase — server-only (bypasses RLS; never import in client code)
APP_SUPABASE_SERVICE_ROLE_KEY=

# Admin auth (Next.js middleware + cookie session, see PROJECT_SPEC §8.5)
APP_ADMIN_PASSWORD=
# 32-byte random hex, generate with: openssl rand -hex 32
APP_SESSION_SECRET=
