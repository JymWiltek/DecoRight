# ──────────────────────────────────────────────────────────────
# DecoRight — env var contract
# Copy this file to `.env.local` and fill in real values.
# Prefix rules (PROJECT_SPEC v1.2):
#   APP_*              → server-only (never exposed to browser)
#   NEXT_PUBLIC_APP_*  → safe for client bundle
# ──────────────────────────────────────────────────────────────

# Supabase — client-visible
NEXT_PUBLIC_APP_SUPABASE_URL=
NEXT_PUBLIC_APP_SUPABASE_ANON_KEY=

# Supabase — server-only (bypasses RLS; never import in client code)
APP_SUPABASE_SERVICE_ROLE_KEY=

# Admin auth (Next.js middleware + cookie session, see PROJECT_SPEC §8.5)
APP_ADMIN_PASSWORD=
# 32-byte random hex, generate with: openssl rand -hex 32
APP_SESSION_SECRET=

# Background-removal providers — required for the auto-cutout pipeline.
# Without at least one of these set, every dropzone upload lands at
# state=cutout_failed and the workbench shows a "no provider configured"
# warning. Replicate is the default (cheap, ~$0.001/img); Remove.bg is
# the fallback / "premium" rerun (~$0.20/img).
REPLICATE_API_TOKEN=
REMOVE_BG_API_KEY=

# Meshy — image-to-3D generator (Phase A, src/lib/meshy.ts).
#
# IMPORTANT: this key is read in TWO independent places, and BOTH
# need to be configured for the full Publish→3D pipeline to work.
# This file only configures the first one (Next.js); the second is
# set out-of-band. See supabase/functions/poll-meshy/DEPLOY.md for
# the full picture.
#
#   1. Next.js server (this file / Vercel env vars)
#      Used by: src/lib/meshy.ts → src/lib/meshy-kickoff.ts
#      When:    operator clicks Publish (kickoff) or the Retry
#               button on a failed row.
#      What:    POSTs to Meshy to start a new task; never polls.
#
#   2. Supabase Edge Function (`supabase secrets set MESHY_API_KEY=...`)
#      Used by: supabase/functions/poll-meshy/index.ts
#      When:    every cron tick (Commit 6's pg_cron, every minute).
#      What:    GETs Meshy task status, downloads finished GLBs.
#
# Without (1) set, Publish falls back to "manual GLB only" (operator
# must hand-upload a .glb; auto-generation is disabled).
# Without (2) set, kickoff still works but generated tasks never get
# polled — rows stay in meshy_status='generating' forever.
#
# For local dev / CI, Meshy ships a public test key that returns
# simulated results in seconds with $0 spend:
#   MESHY_API_KEY=msy_dummy_api_key_for_test_mode_12345678
MESHY_API_KEY=

# ── NOT in this file (server-side-only, set out-of-band) ──────
#
# CRON_SECRET — shared secret between the pg_cron job and the
# poll-meshy Edge Function. Lives in TWO places (must match):
#
#   1. Edge Function secret (Dashboard → Project Settings →
#      Edge Functions → Secrets, name CRON_SECRET):
#      Used by:  Deno.env.get('CRON_SECRET') in the function.
#   2. Row in private._app_config (key = 'cron_secret'), read
#      by the cron job's net.http_post on every tick.
#
# An earlier draft used a Postgres custom GUC (`app.cron_secret`
# via ALTER DATABASE); that path is dead on Supabase managed
# Postgres (permission denied + secret leak in error messages).
# Migration 0018 replaces it with a row in `private._app_config`.
#
# Generate with: encode(gen_random_bytes(32), 'hex')  (in SQL),
# or openssl rand -hex 32 locally.
# Not in .env.local because Next.js does NOT read it — it's only
# meaningful inside the Edge Function runtime + the cron worker.
# See supabase/functions/poll-meshy/DEPLOY.md.
